#!/bin/bash

## Copyright (C) 2026 - 2026 ENCRYPTED SUPPORT LLC <adrelanos@whonix.org>
## See the file COPYING for copying conditions.

## AI-Assisted

## Project-policy wrapper around `github-org-fork`.
## Mirrors Kicksecure and Whonix into the org-ai-assisted GitHub org.

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

## R-082: source every helper-scripts file used directly. The lib
## happens to source these too (transitively) but a future refactor
## that drops a transitive source must not break this consumer.
# shellcheck source=/usr/libexec/helper-scripts/log_run_die.sh
source "${HELPER_SCRIPTS_PATH:-}"/usr/libexec/helper-scripts/log_run_die.sh
# shellcheck source=/usr/libexec/helper-scripts/has.sh
source "${HELPER_SCRIPTS_PATH:-}"/usr/libexec/helper-scripts/has.sh
## Sourced for its LOG_MAX_LEN default (the helper-scripts log()
## reads it to truncate every log line through sanitize-string). The
## lib also pulls in helper-scripts files above; per R-082 those
## are sourced directly in addition.
# shellcheck source=/usr/libexec/developer-meta-files/github-org-lib.bsh
source /usr/libexec/developer-meta-files/github-org-lib.bsh

## Mirror destination: the GitHub org that holds forks of every
## source-org repo. Production target.
readonly MIRROR='org-ai-assisted'

## Source orgs to mirror from. Production list:
readonly SOURCE_ORGS=( 'Kicksecure' 'Whonix' )

## --include-forks: Kicksecure has ~13 repos that are forks of
## upstream projects (grml-debootstrap, tirdad, etc.). github-org-fork
## defaults to skipping forks; add the flag here so the org-ai-assisted
## mirror covers the full Kicksecure surface, not just non-forks.
##
## --sync-branches: keep mirror default branches fast-forwarded from
## upstream every run. Without this, dm-github-fork-sync only creates
## new forks and reconfigures existing ones - it does NOT advance
## branch tips when upstream commits land. Re-running this script
## periodically (cron, or before each release-build) keeps the mirror
## current.
readonly POLICY_FLAGS=(
   --include-forks
   --sync-branches
   --disable-issues
   --disable-wiki
   --disable-projects
   --actions enable
   --workflow-perms read
)

## Per-source exclusions.
##
## Whonix and Kicksecure both have '.github' (org-meta repo) and
## 'canary' (warrant canary). Forking both lands the second-arriving
## source on a target name already taken by the first - GitHub
## returns HTTP 422 'name already exists' on the second fork. We
## process Kicksecure first (Kicksecure wins those two names), then
## skip the same names on the Whonix iteration.
declare -g -A SOURCE_EXCLUDE_RE=(
   ['Whonix']='^(\.github|canary)$'
)

show_help() {
   cat <<'EOF'
Project-policy wrapper around github-org-fork.
Mirrors the Kicksecure and Whonix orgs into the org-ai-assisted org
with the settings the project requires:

  - private source repos skipped
  - issues, wiki, projects disabled on each mirror
  - GitHub Actions enabled on each mirror (so Claude Code can read
    CI logs from the mirror)

Usage (one mode flag is required - no implicit default):
  dm-github-fork-sync --apply     ## sync all source orgs into the mirror
  dm-github-fork-sync --dry-run   ## report planned actions only
  dm-github-fork-sync --help

All extra flags are forwarded to github-org-fork, so --dry-run, -v,
--include / --exclude REGEX, etc. all work.

Auth: ${GITHUB_TOKEN} env var, or chmod-600 ~/.config/github-token.
The token must have admin access to the org-ai-assisted org so that
github-org-fork can create forks under it.
EOF
}

## Intercept --help / -h and --debug up front. --debug enables
## 'set -x' here AND in the spawned github-org-fork (via the flag
## passing the option as an argv element). Other args ('$@') fall
## through to github-org-fork untouched. Mode (--apply / --dry-run)
## is required: github-org-fork itself rejects an absent mode flag,
## but checking up front in the wrapper lets the error message name
## dm-github-fork-sync rather than the spawned tool.
debug_flag=()
positional_args=()
mode_set=0
for arg in "$@"; do
   case "${arg}" in
      -h|--help)
         show_help
         exit 0
         ;;
      --debug)
         set -x
         debug_flag=( --debug )
         ;;
      --apply|--dry-run)
         [ "${mode_set}" -eq 0 ] || die 64 'conflicting mode flags; specify exactly one of --apply / --dry-run'
         mode_set=1
         positional_args+=( "${arg}" )
         ;;
      *)
         positional_args+=( "${arg}" )
         ;;
   esac
done

[ "${mode_set}" -eq 1 ] \
   || { show_help >&2; die 64 'specify exactly one of --apply / --dry-run'; }

has github-org-fork || die 1 "'github-org-fork' not on PATH"

for src in "${SOURCE_ORGS[@]}"; do
   per_src_flags=()
   if [ -n "${SOURCE_EXCLUDE_RE[${src}]:-}" ]; then
      per_src_flags+=( --exclude "${SOURCE_EXCLUDE_RE[${src}]}" )
   fi
   log notice "=== ${src} -> ${MIRROR} ==="
   github-org-fork "${debug_flag[@]}" "${POLICY_FLAGS[@]}" "${per_src_flags[@]}" "${positional_args[@]}" -- "${src}" "${MIRROR}"
done
