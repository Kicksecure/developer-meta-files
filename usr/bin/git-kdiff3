## Safe git external diff driver: opens 'kdiff3' for regular-file diffs. Thin
## wrapper over the shared hardened core (git-review-driver.sh); sibling of
## git-meld and git-diff-review. Surfaces mode / symlink / gitlink-spoof /
## Trojan-Source-Unicode / long-line / binary / driver-skipped changes so a
## review is never silently blind.

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

git_review_self="$(readlink -f -- "${BASH_SOURCE[0]}")"
review_tool="git-kdiff3"

## Invoked indirectly by the sourced git-review-driver.sh (not dead code).
# shellcheck disable=SC2317
display_regular_file() {
   kdiff3 "${1}" "${2}"
}

# shellcheck source=../libexec/developer-meta-files/git-review-driver.sh
source /usr/libexec/developer-meta-files/git-review-driver.sh
