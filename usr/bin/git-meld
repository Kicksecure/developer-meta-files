#!/bin/bash

## Copyright (C) 2026 - 2026 ENCRYPTED SUPPORT LLC <adrelanos@whonix.org>
## See the file COPYING for copying conditions.

## AI-Assisted

## A git external diff driver: opens 'meld' for regular files, and for a
## submodule gitlink change prints the submodule's own 'git diff' between the
## old and new commits (instead of the opaque "Subproject commit <hex>" blob).
##
## Security stance: this is a REVIEW tool. Its overriding invariant is that a
## real change is NEVER rendered as empty / no output -- a change a reviewer
## cannot see is a change an attacker can hide. Every branch below either shows
## the change or fails LOUD; several classes that a plain 'meld' would gloss
## over (mode-only changes, symlink swaps, gitlink spoofing, Trojan-Source
## Unicode, and files git refuses to hand to an external driver at all) are
## surfaced explicitly.

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

self_path="$(readlink -f -- "${BASH_SOURCE[0]}")"

## Dual-mode dispatch.
## As a git external diff driver, git sets GIT_DIFF_PATH_TOTAL and passes the 7
## positional args (path old-file old-hex old-mode new-file new-hex new-mode);
## that is the driver logic below.
## Invoked any other way -- i.e. as 'git meld [<diff args>]' via the one-line
## delegating alias -- re-run 'git diff' with this script wired in as the diff
## driver. A '!'-alias runs from the repo root, so cd into GIT_PREFIX first to
## make relative pathspecs resolve from the directory the user actually ran in
## (parity with a plain 'git diff'); GIT_PREFIX is empty at the root, so this is
## then a no-op.
if [ -z "${GIT_DIFF_PATH_TOTAL:-}" ]; then
   cd -- "${GIT_PREFIX:-.}"

   ## Pre-flight overview with a NON-external diff. This is the ONLY place that
   ## can surface files git never hands to this driver at all: paths marked
   ## 'binary' / '-diff' / 'diff=<driver>' by .gitattributes, blobs git
   ## auto-detects as binary (a NUL byte), and LFS pointers all render as
   ## "Binary files differ" (or nothing) with the per-file driver skipped. The
   ## tree-level summary lists every changed path, rename, and mode change
   ## regardless, so nothing is invisible.
   printf '%s\n' "===== git-meld pre-flight: full change set (no external diff) ====="
   git diff --no-ext-diff --stat --summary --find-renames "$@" || true
   if git diff --no-ext-diff --name-only "$@" 2>/dev/null | grep --quiet -e '\.gitattributes$' -e '^\.gitattributes$'; then
      printf '%s\n' "git-meld: WARNING: this change touches .gitattributes, which can change how OTHER files are diffed (mark them binary/-diff and hide their contents). Review .gitattributes FIRST." >&2
   fi
   printf '%s\n' "===== git-meld per-file diffs ====="

   ## Run 'git diff' as a child and forward its exit code, rather than
   ## 'exec'-ing it (R-103): keeps this wrapper in the process tree. An
   ## explicit 'exit' is still needed because this is not the last statement.
   git -c "diff.external=${self_path}" diff "$@"
   exit "$?"
fi

## Recursion-depth counter, EXPORTED so a re-invoked driver inherits and
## increments it -- a fresh subprocess would otherwise reset it to 1, which is
## why the guard below could never actually fire. See the guard for its use.
[[ -v git_external_level ]] || git_external_level=0
git_external_level=$((git_external_level + 1))
export git_external_level

true "${self_path}: START. git_external_level: ${git_external_level}"

## Unmerged (conflicted) paths: git invokes the external diff driver with ONLY
## the path (one argument), not the usual seven. Open the conflicted
## working-tree file and stop, rather than aborting on the missing args under
## 'nounset'.
if [ "$#" -lt 7 ]; then
   true "${self_path}: unmerged path (one-argument callback): ${1}"
   meld "${1}"
   exit 0
fi

diff_path="${1}"
old_file="${2}"
old_hex="${3}"
old_mode="${4}"
new_file="${5}"
new_hex="${6}"
new_mode="${7}"

true "${self_path}: path=${diff_path} old=${old_hex}/${old_mode} new=${new_hex}/${new_mode}"

## Recursion-depth backstop. Normally inert: the inner submodule diffs below
## use '--no-ext-diff' and never re-enter this driver, so the count stays at 1.
## It only bites if that protection is ever lost and the driver starts nesting
## -- the exported counter then climbs across the re-invoked processes and this
## bails before it runs away.
if [ "${git_external_level}" -ge 3 ]; then
   exit 255
fi

is_submodule_blob() {
   grep --quiet -- '^Subproject commit' "${1}"
}

extract_commit() {
   ## Capture only the hex object name; ignore any trailing suffix such as the
   ## '-dirty' git appends when the submodule working tree has local changes
   ## (otherwise the revision passed to 'git diff' below would be invalid).
   sed --quiet -- 's/^Subproject commit \([0-9a-fA-F]*\).*/\1/p' "${1}"
}

## Argument sanity: modes are six octal digits, object ids are hex or all-zero
## (added/deleted side). Surface anything unexpected rather than trusting it.
for check_mode in "${old_mode}" "${new_mode}"; do
   [[ "${check_mode}" =~ ^[0-7]{6}$ ]] \
      || printf '%s\n' "git-meld: WARNING: unexpected mode '${check_mode}' for '${diff_path}'." >&2
done

## Mode / type change banner. Surfaces mode-only changes (e.g. a data file made
## executable) that a content diff alone would not show, plus any type
## transition (file <-> symlink <-> gitlink).
if [ "${old_mode}" != "${new_mode}" ]; then
   printf '%s\n' "git-meld: MODE CHANGE '${diff_path}': ${old_mode} -> ${new_mode}"
   case "${new_mode}" in
      100755) [ "${old_mode}" = 100755 ] || printf '%s\n' "git-meld: NOTE: '${diff_path}' is now EXECUTABLE (+x)." ;;
   esac
fi

## Symlink: the blob content IS the link target, which meld would show as
## innocuous plain text. Make the target explicit and flag file<->symlink
## transitions, then stop (do not hand a link to meld as a file).
read_target() { if [ "${1}" = /dev/null ] || [ ! -e "${1}" ]; then printf '(none)'; else tr '\n' ' ' < "${1}"; fi; }
if [ "${old_mode:0:2}" = "12" ] || [ "${new_mode:0:2}" = "12" ]; then
   old_target="$(read_target "${old_file}")"
   new_target="$(read_target "${new_file}")"
   printf '%s\n' "git-meld: SYMLINK '${diff_path}': ${old_target} -> ${new_target}"
   exit 0
fi

## Real submodule gitlink? Decide by MODE (160000), NOT by blob content: a
## regular file whose content merely reads 'Subproject commit <hex>' is a SPOOF
## meant to route a real file change through the submodule branch (which never
## opens meld), hiding the file's contents. Mode is authoritative.
if [ "${old_mode:0:2}" = "16" ] || [ "${new_mode:0:2}" = "16" ]; then
   old_commit="$(extract_commit "${old_file}")"
   new_commit="$(extract_commit "${new_file}")"
   printf '%s\n' "Submodule ${diff_path}: ${old_commit:-<none>} -> ${new_commit:-<none>}"

   ## 'git -C' (not 'cd') so an odd/symlinked submodule path cannot redirect us;
   ## verify it is a real git repo before diffing. Never swallow a failure: if
   ## the commits are not present locally, fail LOUD rather than hide the change.
   if ! git -C "${diff_path}" rev-parse --git-dir >/dev/null 2>&1; then
      printf '%s\n' "git-meld: ERROR: submodule '${diff_path}' is not an initialized git repo here; cannot show its diff (init/fetch it). The gitlink change is NOT being hidden." >&2
      exit 1
   fi
   submodule_diff_rc=0
   git -C "${diff_path}" diff --no-ext-diff --find-copies --stat "${old_commit}" "${new_commit}" || submodule_diff_rc=$?
   git -C "${diff_path}" diff --no-ext-diff --find-copies "${old_commit}" "${new_commit}" || submodule_diff_rc=$?
   if [ "${submodule_diff_rc}" != 0 ]; then
      printf '%s\n' "git-meld: ERROR: submodule '${diff_path}' ${old_commit} -> ${new_commit}: its diff could not be shown (commits not present locally? fetch it). The change is NOT being hidden." >&2
      exit 1
   fi
   exit 0
fi

## Content mimics a gitlink but the mode says it is a regular file -> obfuscation.
if is_submodule_blob "${old_file}" || is_submodule_blob "${new_file}"; then
   printf '%s\n' "git-meld: WARNING: '${diff_path}' content mimics a submodule gitlink ('Subproject commit ...') but its mode (${old_mode} -> ${new_mode}) is not 160000. Treating as a REGULAR FILE; inspect closely (possible obfuscation)." >&2
fi

## Trojan-Source scan: bidirectional overrides (U+202A-E, U+2066-9), zero-width
## space, and BOM/ZWNBSP, plus C0 control bytes other than tab/newline/CR. These
## render deceptively (or invisibly) in an editor/meld; warn before opening.
if LC_ALL=C grep --quiet --perl-regexp \
   -e '[\x00-\x08\x0b\x0c\x0e-\x1f]|\xe2\x80[\xaa-\xae]|\xe2\x81[\xa6-\xa9]|\xe2\x80\x8b|\xef\xbb\xbf' \
   -- "${new_file}" 2>/dev/null; then
   printf '%s\n' "git-meld: WARNING: '${diff_path}' contains bidirectional/invisible/control Unicode (possible Trojan-Source). Inspect the raw bytes, not just the rendered diff." >&2
fi

## Regular file: surface a '--stat' summary ('--no-ext-diff' after 'diff';
## '$old_hex'/'$new_hex' are blob ids, no '--'). meld shows the actual file
## diff, so a failed '--stat' does not hide it; still warn rather than swallow.
git diff --no-ext-diff --find-copies --stat "${old_hex}" "${new_hex}" \
   || printf '%s\n' "git-meld: WARNING: '--stat' summary for '${diff_path}' (${old_hex} -> ${new_hex}) failed; opening meld with the full diff anyway." >&2
meld "${old_file}" "${new_file}"

true "${self_path}: END. git_external_level: ${git_external_level}"

exit 0
