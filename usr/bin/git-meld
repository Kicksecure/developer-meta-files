## AI-Assisted

## Safe git external diff driver: opens 'meld' for regular-file diffs, and for a
## submodule gitlink change prints the submodule's own 'git diff'. Thin wrapper
## over the shared hardened core (git-review-driver.sh) that surfaces mode /
## symlink / gitlink-spoof / Trojan-Source-Unicode / long-line / binary /
## driver-skipped changes so a review is never silently blind. See also the
## sibling safe drivers git-kdiff3 and git-diff-review.

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

git_review_self="$(readlink -f -- "${BASH_SOURCE[0]}")"
review_tool="git-meld"

## Invoked indirectly by the sourced git-review-driver.sh (not dead code).
# shellcheck disable=SC2317
display_regular_file() {
   meld "${1}" "${2}"
}

# shellcheck source=../libexec/developer-meta-files/git-review-driver.sh
source /usr/libexec/developer-meta-files/git-review-driver.sh
