set -x
set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

true "INFO: Currently running script: ${BASH_SOURCE[0]} $*"

check-ref-commits-for-unicode "${1}"

git log "...${1}"

git-diff-review "...${1}"

true "$0: OK."
