#!/bin/bash

## Copyright (C) 2026 - 2026 ENCRYPTED SUPPORT LLC <adrelanos@whonix.org>
## See the file COPYING for copying conditions.

set -x
set -e

true "INFO: Currently running script: $BASH_SOURCE $@"

dist_build_internal_run="true"
dist_build_one_parsed="true"
dist_build_target_arch='amd64'

MYDIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

if [ "$MYDIR" = "/usr/bin" ]; then
   true "INFO: Run from: /usr/bin"
   ## XXX: hardcoded path
   derivative_maker_source_code_dir="$HOME/derivative-maker"
else
   true "INFO: Run from: source code folder"
   derivative_maker_source_code_dir="$(cd -- "$MYDIR" && cd -- "../../../../../" && pwd)"
fi

source "$derivative_maker_source_code_dir/help-steps/pre"
source "$derivative_maker_source_code_dir/help-steps/colors"
source "$derivative_maker_source_code_dir/help-steps/variables"

source "/usr/libexec/helper-scripts/log_run_die.sh"

extract_tor_version_from_stanza() {
  local line_buffer line package_name package_version

  line_buffer="${1:-}"
  while read -r line; do
    if [[ "${line}" =~ ^Package: ]]; then
      package_name="$(cut -d' ' -f2 <<< "${line}")"
    elif [[ "${line}" =~ ^Version: ]]; then
      package_version="$(cut -d' ' -f2 <<< "${line}")"
    fi
  done <<< "${line_buffer}"

  if [ "${package_name}" = 'tor' ] && [ -n "${package_version}" ]; then
    printf '%s\n' "${package_version}"
  fi
}

extract_tor_version_from_file() {
  local target_file line_buffer line tor_version

  target_file="${1:-}"
  line_buffer=''
  while read -r line; do
    if [ -z "${line}" ]; then
      tor_version="$(extract_tor_version_from_stanza "${line_buffer}")"
      if [ -z "${tor_version}" ]; then
        line_buffer=''
        continue
      fi
      printf '%s\n' "${tor_version}"
      return 0
    fi
    line_buffer+="${line}"$'\n'
  done < "${target_file}"

  ## Maybe the tor version was the very last stanza?
  tor_version="$(extract_tor_version_from_stanza "${line_buffer}")"
  if [ -n "${tor_version}" ]; then
    printf '%s\n' "${tor_version}"
  fi
}

dm_tor_update_repository() {
  local local_tor_version remote_tor_version

  ## Make sure the proxy is set up properly.
  log_run notice "${derivative_maker_source_code_dir}/build-steps.d/1200_prepare-build-machine" --flavor internal

  ## Create a fresh chroot to work in.
  log_run notice "${derivative_maker_source_code_dir}/build-steps.d/1300_cowbuilder-setup" --flavor internal

  log notice 'Setting cowbuilder file variables.'
  dist_build_multiarch_package_item="$dist_build_target_arch"
  set_cowbuilder_folders

  ## Copy the Tor repository sources and key into the chroot. Fix permissions on both files.
  log_run notice $SUDO_TO_ROOT cp "${dist_build_sources_list_torproject}" "${base_folder}/etc/apt/sources.list.d/torproject.sources"
  log_run notice $SUDO_TO_ROOT chmod 644 "${base_folder}/etc/apt/sources.list.d/torproject.sources"
  log_run notice $SUDO_TO_ROOT cp "${derivative_maker_source_code_dir}/packages/kicksecure/anon-shared-build-apt-sources-tpo/usr/share/anon-shared-build-apt-sources-tpo/tpoarchive-keys.d/torprojectarchive.asc" "${base_folder}/etc/apt/trusted.gpg.d/torprojectarchive.asc"
  log_run notice $SUDO_TO_ROOT chmod 644 "${base_folder}/etc/apt/trusted.gpg.d/torprojectarchive.asc"

  ## Update the apt sources within the chroot.
  log_run notice \
    $SUDO_TO_ROOT \
      $COWBUILDER_PREFIX \
        cowbuilder \
          --architecture "$dist_build_multiarch_package_item" \
          --configfile "$dist_build_pbuilder_config_file" \
          --execute \
          --basepath "$base_folder" \
          --buildplace "$cow_folder" \
          --save-after-login \
          -- \
          /usr/bin/apt-get update

  ## Extract the Tor version numbers from the local and remote repositories.
  log notice 'Extracting Tor version numbers from apt list files.'
  local_tor_version="$(extract_tor_version_from_file "${derivative_maker_source_code_dir}/../derivative-binary/aptrepo_local/kicksecure/dists/local/main/binary-amd64/Packages")"
  remote_tor_version="$(extract_tor_version_from_file "${base_folder}/var/lib/apt/lists/127.0.0.1:9977_tpo_dists_trixie_main_binary-amd64_Packages")"
  log notice "Local Tor version: '${local_tor_version}'"
  log notice "Remote Tor version: '${remote_tor_version}'"

  if [ -z "${local_tor_version}" ]; then
    log warn 'No local Tor version detected, a new version of Tor will be downloaded.'
  fi
  if [ -z "${remote_tor_version}" ]; then
    log error 'No remote Tor version detected!'
    exit 1
  fi

  if dpkg --compare-versions "${local_tor_version}" lt "${remote_tor_version}"; then
    log notice 'Remote Tor version is newer than local Tor version, downloading remote version.'
    log_run notice "${derivative_maker_source_code_dir}/build-steps.d/2100_create-debian-packages" --flavor internal --function download_tpo_packages
  elif dpkg --compare-versions "${local_tor_version}" gt "${remote_tor_version}"; then
    log error 'Remote Tor version is OLDER than local Tor version! Possible rollback attack?'
  else
    log notice 'Remote Tor version matches local Tor version, not updating, OK.'
  fi
}

log notice 'Start.'

dm_tor_update_repository

log notice 'End.'
