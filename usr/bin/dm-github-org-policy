## AI-Assisted

## Apply project-wide GitHub security/policy settings to the source
## organizations (Kicksecure, Whonix). Idempotent and apply-only.
## Run `dm-github-org-policy --help` for the full settings list and
## reasoning.

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

# shellcheck source=/usr/libexec/developer-meta-files/github-org-lib.bsh
source /usr/libexec/developer-meta-files/github-org-lib.bsh
# shellcheck source=/usr/libexec/developer-meta-files/github-policy-lib.bsh
source /usr/libexec/developer-meta-files/github-policy-lib.bsh
# shellcheck source=/usr/libexec/developer-meta-files/github-policy-data.bsh
source /usr/libexec/developer-meta-files/github-policy-data.bsh
## R-082: source every helper-scripts file used directly. The lib
## happens to source these too (transitively) but a future refactor
## that drops a transitive source must not break this consumer.
# shellcheck source=/usr/libexec/helper-scripts/log_run_die.sh
source "${HELPER_SCRIPTS_PATH:-}"/usr/libexec/helper-scripts/log_run_die.sh
# shellcheck source=/usr/libexec/helper-scripts/has.sh
source "${HELPER_SCRIPTS_PATH:-}"/usr/libexec/helper-scripts/has.sh

die_if_not_has github-org-fork

## ===== Per-org policy distinction =====
##
## Two kinds of org are touched by this script:
##
##   SOURCE = canonical upstream org (Kicksecure, Whonix). Holds
##            originals; first-class bug-tracker, the place where
##            contributors and downstream tooling expect to file
##            issues, follow Discussions, watch the project.
##            Defaults: has_issues=true, has_projects=true,
##            has_discussions=true.
##   MIRROR = fork org (org-ai-assisted) for AI-assisted dev work.
##            Holds 100% forks. Issues / Projects / Discussions
##            belong on the SOURCE - filing upstream is the
##            contract; the MIRROR's mirror-side trackers must
##            stay closed or contributors get split inboxes.
##            Defaults: has_issues=false, has_projects=false,
##            has_discussions=false.
##
## Vocabulary aligns with dm-github-fork-sync, which already uses
## SOURCE_ORGS / MIRROR.
readonly SOURCE_ORGS=( 'Kicksecure' 'Whonix' )
readonly MIRROR_ORGS=( 'org-ai-assisted' )

## Active policy targets. SOURCE_ORGS is currently commented out
## pending an admin token scoped to those orgs - uncomment once
## available; the per-org case statements below already handle
## both kinds.
# readonly ORGS=( "${SOURCE_ORGS[@]}" "${MIRROR_ORGS[@]}" )
readonly ORGS=( "${MIRROR_ORGS[@]}" )

## Echo 'source' or 'mirror' for the named org; die on an unknown
## name. apply_repo_policy pivots on this to pick between
## POLICY_REPO_SOURCE / POLICY_REPO_MIRROR (in
## github-policy-data.bsh); a typo'd org would otherwise silently
## get the wrong defaults.
org_kind() {
   local org name
   org="$1"
   for name in "${SOURCE_ORGS[@]}"; do
      [ "${name}" = "${org}" ] && { printf '%s\n' source; return 0; }
   done
   for name in "${MIRROR_ORGS[@]}"; do
      [ "${name}" = "${org}" ] && { printf '%s\n' mirror; return 0; }
   done
   log error "org_kind: '${org}' not in SOURCE_ORGS or MIRROR_ORGS"
   return 1
}

readonly RULESET_NAME_BRANCH='dm-github-org-policy default-branch protection'
readonly RULESET_NAME_TAG='dm-github-org-policy tag protection'
readonly CODE_SEC_CONFIG_NAME='dm-github-org-policy code security'


## Modes are mutually exclusive; one must be passed explicitly. No
## implicit default - running this tool without a mode flag would
## otherwise apply mutations under "what the operator forgot to type"
## semantics. mode_set is checked after parsing.
dry_run=0
verbose=0
mode=''
mode_set=0
positional=()

show_help() {
   cat <<'EOF'
Apply project-wide GitHub security/policy settings to the source
organizations (Kicksecure, Whonix) and the mirror org
(org-ai-assisted). Idempotent and apply-only - never disables a
setting that was already on.

Usage (one mode flag is required - no implicit default):
  dm-github-org-policy --apply         apply policy
  dm-github-org-policy --dry-run       report planned changes only
  dm-github-org-policy --audit         read-only inspection
  dm-github-org-policy --policy-dump   print the active policy table
                                       (cats github-policy-data.bsh)
  dm-github-org-policy --help

Run 'dm-github-org-policy --policy-dump' for the full table of what
gets applied (bodies, endpoints, methods, labels, SOURCE vs MIRROR
diffs).

Auth:
  ${GITHUB_TOKEN} env var, or chmod-600 ~/.config/github-token.
  Classic PAT needs admin:org + repo. Fine-grained PAT needs
  Administration r/w + Code security r/w + Webhooks r/w +
  Members r/w (the last for 2FA enforcement audit).

Note on signed commits + UI merging:
  GitHub's "Merge" and "Squash" buttons re-sign with the web-flow
  GPG key. "Rebase and merge" does NOT re-sign; it fails on PRs
  with unsigned contributor commits.
EOF
}

## Parse + post-check + dep pre-flight + warn-flag init. See the
## docstring on policy_tool_init in github-policy-lib.bsh; this tool
## takes no positional args.
policy_tool_init 0 "$@"

## Idempotent code-security-configuration upsert + attach + default.
## Replaces the deprecated PATCH /orgs/{org} security-defaults fields
## and /orgs/{org}/{product}/enable_all endpoints with the modern
## /orgs/{org}/code-security/configurations API. Three steps per org:
##   1. find-or-create the configuration named CODE_SEC_CONFIG_NAME
##   2. attach it to all existing repos (scope=all)
##   3. set it as the default for new repos (default_for_new_repos=all)
##
## Configuration body: POLICY_CODE_SECURITY in github-policy-data.bsh
## (rationale for each enabled / disabled feature lives there).
apply_code_security_config() {
   local org config_body existing_id list_body create_body
   local attach_endpoint default_endpoint

   org="$1"

   ## Inject the dynamic 'name' field via jq --arg.
   config_body="$(jq -n --arg name "${CODE_SEC_CONFIG_NAME}" -- \
      "${POLICY_CODE_SECURITY} + {name: \$name}")"

   if [ "${dry_run}" = '1' ]; then
      log notice "DRY-RUN: ${org}: upsert code-security configuration ${CODE_SEC_CONFIG_NAME}"
      log notice "DRY-RUN: ${org}: attach code-security configuration scope=all"
      log notice "DRY-RUN: ${org}: set code-security configuration default_for_new_repos=all"
      return 0
   fi

   ## Find existing configuration by name. policy_api_call's body-
   ## capture (6th arg) populates list_body on success so we can read
   ## .id without re-implementing the status+warn dance.
   policy_api_call "${org}: list code-security configurations" \
      GET "/orgs/${org}/code-security/configurations?per_page=100" '' '' list_body \
      || return 1

   existing_id="$(printf '%s' "${list_body}" \
      | jq -r --arg name "${CODE_SEC_CONFIG_NAME}" -- \
        '.[] | select(.name == $name) | .id' \
      | head --lines=1)"

   if [ -n "${existing_id}" ] && [ "${existing_id}" != 'null' ]; then
      ## Numeric + length cap; see GHORG_MAX_ID_LEN comment in lib.
      if ! [[ "${existing_id}" =~ ^[0-9]+$ ]] || \
         [ "${#existing_id}" -gt "${GHORG_MAX_ID_LEN}" ]; then
         log warn "'${org}': code-security config id '${existing_id}' not a valid numeric id"
         policy_warn_seen=1
         return 1
      fi
      policy_api_call "${org}: update code-security configuration id=${existing_id}" \
         PATCH "/orgs/${org}/code-security/configurations/${existing_id}" \
         "${config_body}" || true
   else
      ## POST returns the new config object including its id; we need
      ## the id for the attach + default calls.
      policy_api_call "${org}: create code-security configuration" \
         POST "/orgs/${org}/code-security/configurations" "${config_body}" '' create_body \
         || return 1
      existing_id="$(printf '%s' "${create_body}" | jq -r -- '.id')"
      if ! [[ "${existing_id}" =~ ^[0-9]+$ ]] || \
         [ "${#existing_id}" -gt "${GHORG_MAX_ID_LEN}" ]; then
         log warn "'${org}': new code-security config id '${existing_id}' not a valid numeric id"
         policy_warn_seen=1
         return 1
      fi
      ## The generic 'ok:' line emitted by policy_api_call above does
      ## not include the id (the label was set before the body was
      ## captured). Operator-facing log gets one more line that names
      ## the id so a follow-up audit / GitHub UI lookup is unambiguous.
      log notice "ok: ${org}: created code-security configuration id=${existing_id}"
   fi

   ## Attach to all existing repos in the org.
   ## The ATTACH and DEFAULTS endpoints embed the configuration id;
   ## resolve __ID__ here, then __ORG__ is resolved by the dispatcher.
   attach_endpoint="${POLICY_CODE_SECURITY_ATTACH_ENDPOINT_ORG//__ID__/${existing_id}}"
   policy_api_call "${org}: ${POLICY_CODE_SECURITY_ATTACH_LABEL}" \
      "${POLICY_CODE_SECURITY_ATTACH_METHOD}" \
      "${attach_endpoint//__ORG__/${org}}" \
      "$(jq -n -- "${POLICY_CODE_SECURITY_ATTACH}")" \
      || true

   ## Make this configuration the default for newly created repos.
   default_endpoint="${POLICY_CODE_SECURITY_DEFAULTS_ENDPOINT_ORG//__ID__/${existing_id}}"
   policy_api_call "${org}: ${POLICY_CODE_SECURITY_DEFAULTS_LABEL}" \
      "${POLICY_CODE_SECURITY_DEFAULTS_METHOD}" \
      "${default_endpoint//__ORG__/${org}}" \
      "$(jq -n -- "${POLICY_CODE_SECURITY_DEFAULTS}")" \
      || true
}

## Org-level settings: fork-PR approval, workflow permissions, allowed
## actions, 2FA SKIP, member policy, code-security configuration,
## branch and tag rulesets, PAT and App SKIPs.
##
## Pure dispatch table - all policy data (bodies, endpoints, methods,
## labels, UI URLs) lives in github-policy-data.bsh.
apply_org_policy() {
   local org kind bypass_var

   org="$1"
   kind="$(org_kind "${org}")" || return 1

   log notice "=== org policy: ${org} ==="

   ## 1. Fork-PR contributor approval.
   policy_apply_org "${org}" FORK_PR_APPROVAL

   ## 2. Default workflow GITHUB_TOKEN permissions.
   policy_apply_org "${org}" WORKFLOW_PERMS

   ## 3. Allowed Actions scope + allow-list (two calls).
   policy_apply_org "${org}" ACTIONS_SCOPE
   policy_apply_org "${org}" ACTIONS_ALLOWLIST ENDPOINT

   ## 4. Member-side org policy.
   policy_apply_org "${org}" MEMBERS

   ## 4b. 2FA enforcement (UI-only).
   policy_skip_ui "${org}" 2FA

   ## 5+6. Code security via the Code Security Configurations API.
   apply_code_security_config "${org}" || true

   ## 7. Org-level branch ruleset. Bypass actor list pivots on
   ##    org_kind via the constant naming convention.
   bypass_var="POLICY_RULESET_BYPASS_${kind^^}"
   policy_upsert_org_ruleset "${org}" "${RULESET_NAME_BRANCH}" \
      "$(policy_branch_ruleset_body "${RULESET_NAME_BRANCH}" org "${!bypass_var}")" \
      || true

   ## 8. Org-level tag ruleset.
   policy_upsert_org_ruleset "${org}" "${RULESET_NAME_TAG}" \
      "$(policy_tag_ruleset_body "${RULESET_NAME_TAG}" org)" \
      || true

   ## 9. PAT policy toggles (UI-only).
   policy_skip_ui "${org}" PAT

   ## 10. GitHub App / OAuth App install policies (UI-only - two URLs).
   log notice "skip: ${org}: ${POLICY_APPS_LABEL} - see ${POLICY_APPS_UI_URL_INSTALLATIONS//__ORG__/${org}} and ${POLICY_APPS_UI_URL_OAUTH//__ORG__/${org}}"
}

## One-line GET-and-print helper for audit_org_state. Args:
##   $1 = label, $2 = API path, $3 = jq filter (default '.').
audit_get() {
   local label path jq_filter result status body extracted

   label="$1"
   path="$2"
   jq_filter="${3:-.}"

   result="$(ghorg_api GET "${path}")" || {
      log notice "  ${label}: <api error>"
      return 0
   }
   status="$(ghorg_status_of "${result}")"
   if [ "${status}" != '200' ]; then
      log notice "  ${label}: HTTP ${status}"
      return 0
   fi
   body="$(ghorg_body_of "${result}")"
   extracted="$(printf '%s' "${body}" \
      | jq -r -- "${jq_filter}" 2>/dev/null \
      | tr -- '\n' ' ')"
   log notice "  ${label}: ${extracted:0:200}"
}

## Read-only inspection of an org's current security/policy state.
## Does no PATCH/PUT/POST. Designed to be run before --apply so the
## operator can spot the change most likely to surprise them: an
## Allowed-Actions tightening that breaks workflows pinned to
## unverified third-party actions.
audit_org_state() {
   local org result status body count names
   local actions_result actions_status actions_body
   local allowed_actions enabled_repos
   local ruleset_body ruleset_name ids id member
   local pending approved installs install_line total no_secret
   local repos repo missing_count have_count

   org="$1"

   log notice "=== audit: ${org} ==="

   audit_get 'fork-PR approval policy' \
      "/orgs/${org}/actions/permissions/fork-pr-contributor-approval" \
      '.approval_policy // "(unset)"'

   audit_get 'workflow GITHUB_TOKEN permissions' \
      "/orgs/${org}/actions/permissions/workflow" \
      '"default=" + (.default_workflow_permissions // "?") + ", can_approve_PRs=" + ((.can_approve_pull_request_reviews // false) | tostring)'

   ## /actions/permissions/selected-actions returns 409 when
   ## allowed_actions != "selected"; suppress the call in that case
   ## and print "(N/A)" instead of a noisy 409.
   allowed_actions=''
   actions_result="$(ghorg_api GET "/orgs/${org}/actions/permissions")" || true
   actions_status="$(ghorg_status_of "${actions_result}")"
   if [ "${actions_status}" = '200' ]; then
      actions_body="$(ghorg_body_of "${actions_result}")"
      ## allowed_actions also gates a downstream conditional below;
      ## the comparison there is exact-string against literals so a
      ## hostile-byte value just falls into the N/A branch.
      allowed_actions="$(printf '%s' "${actions_body}" | jq --raw-output -- '.allowed_actions // "?"')"
      enabled_repos="$(printf '%s' "${actions_body}" | jq --raw-output -- '.enabled_repositories // "?"')"
      log notice "  actions allowed_actions: enabled_repos=${enabled_repos}, allowed_actions=${allowed_actions}"
   else
      log notice "  actions allowed_actions: HTTP ${actions_status}"
   fi

   if [ "${allowed_actions}" = 'selected' ]; then
      audit_get 'selected-actions allow-list' \
         "/orgs/${org}/actions/permissions/selected-actions" \
         '"github_owned=" + ((.github_owned_allowed // false) | tostring) + ", verified=" + ((.verified_allowed // false) | tostring) + ", patterns=" + ((.patterns_allowed // []) | length | tostring)'
   else
      log notice "  selected-actions allow-list: (N/A while allowed_actions=${allowed_actions:-?})"
   fi

   audit_get '2FA required for org members' \
      "/orgs/${org}" \
      '.two_factor_requirement_enabled // false'

   audit_get 'code-security defaults for new repos' \
      "/orgs/${org}" \
      '"secret=" + ((.secret_scanning_enabled_for_new_repositories // false) | tostring) + ", push_prot=" + ((.secret_scanning_push_protection_enabled_for_new_repositories // false) | tostring) + ", dep_alerts=" + ((.dependabot_alerts_enabled_for_new_repositories // false) | tostring) + ", dep_updates=" + ((.dependabot_security_updates_enabled_for_new_repositories // false) | tostring) + ", dep_graph=" + ((.dependency_graph_enabled_for_new_repositories // false) | tostring)'

   ## Members without 2FA - the list that would be removed if 2FA
   ## enforcement were enabled. Paginate; stop after a sensible cap to
   ## avoid runaway output if the org has many such members.
   log notice '  members lacking 2FA (would lose org access until they enroll):'
   result="$(ghorg_api GET "/orgs/${org}/members?filter=2fa_disabled&per_page=100")" || true
   status="$(ghorg_status_of "${result}")"
   if [ "${status}" = '200' ]; then
      body="$(ghorg_body_of "${result}")"
      count="$(printf '%s' "${body}" | jq -- 'length')"
      if [ "${count}" = '0' ]; then
         log notice '    (none)'
      else
         names="$(printf '%s' "${body}" | jq -r -- '.[].login')"
         while IFS= read -r member; do
            [ -z "${member}" ] && continue
            log notice "    - ${member}"
         done <<< "${names}"
      fi
   else
      log notice "    HTTP ${status} (need admin:org / Members read scope)"
   fi

   ## Existing rulesets matching the names we'd upsert (branch + tag).
   result="$(ghorg_api GET "/orgs/${org}/rulesets?per_page=100")" || true
   status="$(ghorg_status_of "${result}")"
   if [ "${status}" = '200' ]; then
      ruleset_body="$(ghorg_body_of "${result}")"
      for ruleset_name in "${RULESET_NAME_BRANCH}" "${RULESET_NAME_TAG}"; do
         log notice "  existing rulesets named \"${ruleset_name}\":"
         ids="$(printf '%s' "${ruleset_body}" \
            | jq -r --arg name "${ruleset_name}" -- \
              '.[] | select(.name == $name) | .id' || true)"
         if [ -z "${ids}" ]; then
            log notice '    (none; --apply would create one)'
         else
            while IFS= read -r id; do
               [ -z "${id}" ] && continue
               log notice "    - id=${id}"
            done <<< "${ids}"
         fi
      done
   else
      log notice "  rulesets list: HTTP ${status} (token may lack admin:org)"
   fi

   ## Personal access tokens: count pending requests + count approved
   ## fine-grained PATs accessing the org. Both indicate the
   ## fine-grained PAT system is in active use, which is informative
   ## context for the operator deciding whether to flip the UI policy
   ## toggles (the toggles are not REST-settable - see apply_org_policy).
   log notice '  fine-grained PAT activity:'
   result="$(ghorg_api GET "/orgs/${org}/personal-access-token-requests?per_page=1")" || true
   status="$(ghorg_status_of "${result}")"
   case "${status}" in
      200)
         ## Count via the JSON length on this page; use a HEAD-style
         ## follow-up if exact totals matter (skipped for simplicity).
         pending="$(ghorg_body_of "${result}" | jq -- 'length' 2>/dev/null || printf '%s' '?')"
         log notice "    pending requests on first page: ${pending}"
         ;;
      404|403)
         log notice "    requests endpoint: HTTP ${status} (approval flow may be off / token lacks scope)"
         ;;
      *)
         log notice "    requests endpoint: HTTP ${status}"
         ;;
   esac
   result="$(ghorg_api GET "/orgs/${org}/personal-access-tokens?per_page=1")" || true
   status="$(ghorg_status_of "${result}")"
   case "${status}" in
      200)
         approved="$(ghorg_body_of "${result}" | jq -- 'length' 2>/dev/null || printf '%s' '?')"
         log notice "    approved tokens on first page: ${approved}"
         ;;
      *)
         log notice "    approved tokens endpoint: HTTP ${status} (token may lack admin:org)"
         ;;
   esac

   ## Installed GitHub Apps. List names so operator can verify the set
   ## is the intended one before deciding whether to lock down installs.
   log notice '  installed GitHub Apps:'
   result="$(ghorg_api GET "/orgs/${org}/installations?per_page=100")" || true
   status="$(ghorg_status_of "${result}")"
   if [ "${status}" = '200' ]; then
      installs="$(ghorg_body_of "${result}" \
         | jq -r -- '.installations[]? | "    - " + (.app_slug // "?") + " (id=" + ((.id // 0) | tostring) + ")"' \
         2>/dev/null || true)"
      if [ -z "${installs}" ]; then
         log notice '    (none)'
      else
         while IFS= read -r install_line; do
            [ -z "${install_line}" ] && continue
            log notice "${install_line}"
         done <<< "${installs}"
      fi
   else
      log notice "    HTTP ${status}"
   fi

   ## Org webhooks: any without a configured `secret` are a Critical
   ## risk per the OSSF Scorecard "Webhooks" check. The GitHub API
   ## never returns the secret value itself; presence is reflected as
   ## a non-empty placeholder in `.config.secret`. Absent or empty
   ## means no secret configured - the webhook accepts unauthenticated
   ## payloads.
   log notice '  org webhooks (Scorecard "Webhooks" check):'
   result="$(ghorg_api GET "/orgs/${org}/hooks?per_page=100")" || true
   status="$(ghorg_status_of "${result}")"
   if [ "${status}" = '200' ]; then
      total="$(ghorg_body_of "${result}" | jq -- 'length' 2>/dev/null || printf '%s' '?')"
      no_secret="$(ghorg_body_of "${result}" \
         | jq -- '[.[] | select(.config.secret == null or .config.secret == "")] | length' \
         2>/dev/null || printf '%s' '?')"
      if [ "${total}" = '0' ]; then
         log notice '    (none configured)'
      else
         log notice "    total=${total}, lacking secret=${no_secret}"
      fi
   else
      log notice "    HTTP ${status} (token may lack admin:org_hook scope)"
   fi

   ## Dependabot config-file presence: the OSSF Scorecard
   ## "Dependency-Update-Tool" check looks for .github/dependabot.yml
   ## file presence specifically, so even though our org-level code-
   ## security config enables Dependabot alerts, repos missing the
   ## file still fail Scorecard. This audit counts repos with vs
   ## without and lists the missing ones as a worklist.
   log notice '  dependabot.yml presence (Scorecard "Dependency-Update-Tool"):'
   repos="$(ghorg_list_repos "${org}" 0 0 1 | sort --unique)"
   if [ -z "${repos}" ]; then
      log notice '    (no public non-archived repos)'
   else
      missing_count=0
      have_count=0
      while IFS= read -r repo; do
         [ -z "${repo}" ] && continue
         result="$(ghorg_api GET "/repos/${org}/${repo}/contents/.github/dependabot.yml")" || true
         status="$(ghorg_status_of "${result}")"
         if [ "${status}" = '200' ]; then
            have_count=$(( have_count + 1 ))
         else
            missing_count=$(( missing_count + 1 ))
            log notice "    - ${org}/${repo}"
         fi
      done <<< "${repos}"
      log notice "    have=${have_count}, missing=${missing_count}"
   fi
}

## Per-repo settings - only the ones with no org-wide alternative.
## Pivots on org_kind to pick the right body from
## github-policy-data.bsh (POLICY_REPO_SOURCE / POLICY_REPO_MIRROR;
## diff table is in the data file).
apply_repo_policy() {
   local owner repo kind

   owner="$1"
   repo="$2"

   ghorg_validate_name "${owner}" user || return 1
   ghorg_validate_name "${repo}"  repo || return 1

   ## org_kind picks REPO_SOURCE or REPO_MIRROR via the constant
   ## naming convention.
   kind="$(org_kind "${owner}")" || return 1
   policy_apply_repo "${owner}" "${repo}" "REPO_${kind^^}" ENDPOINT
}

main() {
   local org repos repo
   if [ "${mode}" = 'audit' ]; then
      for org in "${ORGS[@]}"; do
         audit_org_state "${org}"
      done
      return 0
   fi

   for org in "${ORGS[@]}"; do
      apply_org_policy "${org}"

      log notice "=== repo policy: ${org} ==="
      ## Public, non-archived repos (forks INCLUDED). The org-level
      ## enable_all endpoints already cover security products on every
      ## repo; this loop is just for has_wiki / has_issues which have
      ## no org-wide API.
      ##
      ## Forks are deliberately included. The org-ai-assisted mirror
      ## holds 100% forks of the upstream Kicksecure / Whonix repos;
      ## excluding forks here would silently no-op the entire per-repo
      ## phase against that org. Upstream Kicksecure / Whonix repos
      ## have fork=false so the flip is a no-op there.
      repos="$(ghorg_list_repos "${org}" 0 0 1 | sort --unique)"
      if [ -z "${repos}" ]; then
         log notice "no repos matched in '${org}'"
         continue
      fi

      ## Sequential per-repo apply: one PATCH per repo for a small
      ## org (~12 repos) is fast enough not to need backgrounding,
      ## and a sequential loop lets policy_warn_seen mutations from
      ## the lib propagate back to this scope without a tempfile
      ## or per-pid wait dance.
      while IFS= read -r repo; do
         [ -z "${repo}" ] && continue
         apply_repo_policy "${org}" "${repo}"
      done <<< "${repos}"
   done

   [ "${policy_warn_seen}" -eq 1 ] && return 1
   return 0
}

main
