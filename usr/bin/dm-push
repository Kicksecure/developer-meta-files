#!/bin/bash

## Copyright (C) 2025 - 2025 ENCRYPTED SUPPORT LLC <adrelanos@whonix.org>
## See the file COPYING for copying conditions.

#set -x
set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit

MYDIR="$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" && pwd )"

# shellcheck source=/usr/libexec/helper-scripts/parallel.bsh
source "${HELPER_SCRIPTS_PATH:-}"/usr/libexec/helper-scripts/parallel.bsh

# shellcheck source=/usr/libexec/helper-scripts/log_run_die.sh
source "${HELPER_SCRIPTS_PATH:-}"/usr/libexec/helper-scripts/log_run_die.sh

## Shared push gate (also sourced by dm-packaging-helper-script).
## Prefer the in-tree copy alongside this script during dev runs;
## fall back to the installed path.
git_helpers_lib="${MYDIR}/../libexec/developer-meta-files/git-helpers.bsh"
test -r "${git_helpers_lib}" || git_helpers_lib="/usr/libexec/developer-meta-files/git-helpers.bsh"
# shellcheck source=/usr/libexec/developer-meta-files/git-helpers.bsh
source "${git_helpers_lib}"

log_level=info

readonly DM_GITHUB_MIRROR='org-ai-assisted'

## Drop `--always` so describe fails (instead of silently returning a
## SHA) when there is no tag; the tag-push branch then runs only when
## a real tag exists.
git_tag_nearest=""
git_tag_nearest="$(git describe --abbrev=0 2>/dev/null)" || git_tag_nearest=""

## Map each backgrounded push's PID to a human-readable label so a
## failure can be reported as e.g. "main -> github-kicksecure" rather
## than "at least one push failed".
## Note: `declare -A push_label` alone leaves the array "unset" for
## nounset purposes; the explicit `=()` marks it set so `${#arr[@]}`
## works on the empty case (no eligible remotes / branches).
declare -A push_label=()

queue_branch_refspec() {
   local branch="$1"
   local remote="$2"
   local -n refspecs_ref="$3"

   if ! git rev-parse --verify "refs/heads/$branch" &>/dev/null ; then
      #log info "'refs/heads/$branch' existing: no"
      return 0
   fi
   #log info "'refs/heads/$branch' existing: yes"

   ## internal_git_diff dispatches between the local (tracking-ref)
   ## and remote (ls-remote) gate based on DM_GATE_LS_REMOTE; in both
   ## variants 0 = differs (push needed), 1 = identical (skip).
   if ! internal_git_diff "$branch" "$remote" ; then
      log info "'refs/heads/$branch' up-to-date on '$remote': yes"
      return 0
   fi

   log info "'refs/heads/$branch' up-to-date on '$remote': no"
   log_run info git verify-commit "refs/heads/$branch" &>/dev/null
   refspecs_ref+=( "refs/heads/$branch:refs/heads/$branch" )
}

queue_tag_refspec() {
   local tag="$1"
   local -n refspecs_ref="$2"
   ## Tags live in the global refs/tags/ namespace, not per-remote, so
   ## there is no local remote-tracking ref to gate against without an
   ## ls-remote round-trip. Always queue the tag; if the remote already
   ## has it at the same SHA the server short-circuits with "= up to
   ## date" inside the same atomic push.
   log_run info git verify-tag "refs/tags/$tag" &>/dev/null
   refspecs_ref+=( "refs/tags/$tag:refs/tags/$tag" )
}

## TODO: qubes-template-kicksecure qubes-template-whonix

for git_remote in github-kicksecure github-whonix adrelanos "$DM_GITHUB_MIRROR" ; do
   if ! git remote get-url -- "${git_remote}" &>/dev/null ; then
      continue
   fi

   log info "--------"

   refspec_list=()

   queue_branch_refspec main    "${git_remote}" refspec_list
   queue_branch_refspec master  "${git_remote}" refspec_list
   ## TODO: Debian 14 / forky
   queue_branch_refspec trixie  "${git_remote}" refspec_list

   if [ -n "$git_tag_nearest" ]; then
      queue_tag_refspec "$git_tag_nearest" refspec_list
   fi

   if [ "${#refspec_list[@]}" -eq 0 ]; then
      continue
   fi

   ## --atomic: branch and tag pushes to the same remote succeed
   ##   together or fail together; no mixed-state outcomes.
   ## --porcelain: per-ref machine-readable status lines for
   ##   diagnosable failures via parallel_failures.
   log_run info git push --atomic --porcelain -- "${git_remote}" "${refspec_list[@]}" &
   push_label[$!]="${refspec_list[*]} -> ${git_remote}"
done

if ! parallel_wait push_label ; then
   log error "failed pushes:"
   log error "${parallel_failures[@]}"
   exit 1
fi

log notice "OK."
