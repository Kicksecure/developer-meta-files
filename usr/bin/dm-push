#!/bin/bash

## Copyright (C) 2025 - 2026 ENCRYPTED SUPPORT LLC <adrelanos@whonix.org>
## See the file COPYING for copying conditions.

## AI-Assisted

## Atomic per-remote push of every existing branch + every tip tag
## to every locally-configured mirror remote.

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

MYDIR="$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" && pwd )"

git_helpers_lib="${MYDIR}/../libexec/developer-meta-files/git-helpers.bsh"
test -r "${git_helpers_lib}" || git_helpers_lib="/usr/libexec/developer-meta-files/git-helpers.bsh"
# shellcheck source=../libexec/developer-meta-files/git-helpers.bsh
source "${git_helpers_lib}"

log_level=info

internal_git_push_atomic_all_remotes

log notice "OK."
