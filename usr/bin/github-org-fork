#!/bin/bash

## Copyright (C) 2026 - 2026 ENCRYPTED SUPPORT LLC <adrelanos@whonix.org>
## See the file COPYING for copying conditions.

## AI-Assisted

## Fork every selected repository from a source GitHub user/org into a
## target user/org. Idempotent. Optional flags re-apply per-repo
## settings on the target side. Run `github-org-fork --help` for full
## usage.

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

# shellcheck source=../libexec/developer-meta-files/github-org-lib.bsh
source /usr/libexec/developer-meta-files/github-org-lib.bsh

include_private=0
include_archived=0
include_forks=0
## --include / --exclude can each be passed multiple times; OR-combine
## the patterns so a wrapper-supplied filter (e.g. dm-github-fork-sync's
## per-source SOURCE_EXCLUDE_RE) is not silently overridden by a
## user-supplied --exclude on the same command line. Stored as arrays
## during parsing; OR-combined into a single regex below.
include_re_list=()
exclude_re_list=()
include_re=''
exclude_re=''
disable_issues=0
disable_wiki=0
disable_projects=0
actions_state='leave'    ## enable | disable | leave
workflow_perms='leave'   ## read | write | leave
sync_branches=0
## Mode is mutually exclusive; one of --apply / --dry-run must be
## passed explicitly. No implicit default.
dry_run=0
mode_set=0
verbose=0

show_help() {
  cat <<'EOF'
Fork every selected repo from a source GitHub user/org into a target
user/org. Idempotent: existing forks are left in place; only missing
ones are created. Optional flags also (re-)apply per-repo settings on
the target side, so the script doubles as a drift corrector on every
run.

Usage (one mode flag is required - no implicit default):
  github-org-fork --apply   [OPTIONS] <source-owner> <target-owner>
  github-org-fork --dry-run [OPTIONS] <source-owner> <target-owner>

Options:
  --apply              perform fork creation + per-repo configuration
  --dry-run            report planned actions, do nothing
  --include-private    include private repos       (default: skip)
  --include-archived   include archived repos      (default: skip)
  --include-forks      include forks of other repos (default: skip)
  --include REGEX      only repos whose name matches REGEX
  --exclude REGEX      drop repos whose name matches REGEX
  --disable-issues     turn off issues on each target repo
  --disable-wiki       turn off wiki on each target repo
  --disable-projects   turn off projects on each target repo
  --actions {enable|disable|leave}
                       set Actions state on each target repo
                       (default: leave settings unchanged)
  --workflow-perms {read|write|leave}
                       set default GITHUB_TOKEN permissions in target
                       workflows (default: leave)
  --sync-branches      after fork-create + configure, fast-forward each
                       target repo's default branch from upstream via
                       POST /repos/{owner}/{repo}/merge-upstream. 409
                       (diverged) and 422 (branch missing) become warns.
  -v, --verbose        print each API call's effect
  -h, --help           show this help and exit

Auth:
  ${GITHUB_TOKEN} env var, or chmod-600 ~/.config/github-token. Token
  needs `repo` scope; for --actions or --workflow-perms it also needs
  `workflow`.
EOF
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --debug)
      ## set -x here AND inside the lib (sourced above); 'set -x' is
      ## a shell-local option, sourced lib functions inherit it.
      set -x
      shift
      ;;
    --include-private)
      include_private=1
      shift
      ;;
    --include-archived)
      include_archived=1
      shift
      ;;
    --include-forks)
      include_forks=1
      shift
      ;;
    --include)
      [ "$#" -ge 2 ] || die 64 "missing value for --include"
      include_re_list+=( "$2" )
      shift 2
      ;;
    --exclude)
      [ "$#" -ge 2 ] || die 64 "missing value for --exclude"
      exclude_re_list+=( "$2" )
      shift 2
      ;;
    --disable-issues)
      disable_issues=1
      shift
      ;;
    --disable-wiki)
      disable_wiki=1
      shift
      ;;
    --disable-projects)
      disable_projects=1
      shift
      ;;
    --actions)
      [ "$#" -ge 2 ] || die 64 "missing value for --actions"
      case "$2" in
        enable|disable|leave)
          actions_state="$2"
          ;;
        *)
          die 64 "invalid --actions value: '$2'"
          ;;
      esac
      shift 2
      ;;
    --workflow-perms)
      [ "$#" -ge 2 ] || die 64 "missing value for --workflow-perms"
      case "$2" in
        read|write|leave)
          workflow_perms="$2"
          ;;
        *)
          die 64 "invalid --workflow-perms value: '$2'"
          ;;
      esac
      shift 2
      ;;
    --sync-branches)
      sync_branches=1
      shift
      ;;
    --apply)
      [ "${mode_set}" -eq 0 ] || die 64 'conflicting mode flags; specify exactly one of --apply / --dry-run'
      mode_set=1
      shift
      ;;
    --dry-run)
      [ "${mode_set}" -eq 0 ] || die 64 'conflicting mode flags; specify exactly one of --apply / --dry-run'
      dry_run=1
      mode_set=1
      shift
      ;;
    -v|--verbose)
      verbose=1
      shift
      ;;
    -h|--help)
      show_help
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      die 64 "unknown option: '$1'"
      ;;
    *)
      break
      ;;
  esac
done

if [ "$#" -ne 2 ]; then
  show_help >&2
  exit 64
fi

source_owner="$1"
target_owner="$2"

[ "${mode_set}" -eq 1 ] \
   || { show_help >&2; die 64 'specify exactly one of --apply / --dry-run'; }

## OR-combine multi-flag --include / --exclude lists into single
## regexes (extended) consumed by ghorg_filter_names below. Each
## individual pattern wrapped in (...) so alternation between user-
## supplied and wrapper-supplied filters cannot be unbalanced by
## bare '|' inside one of them.
combine_alt() {
  local -n list_ref="$1"
  local item out=''
  for item in "${list_ref[@]}"; do
    ## Empty pattern is treated as "no filter at this slot". A wrapper
    ## that forwards an optional regex with --exclude "${EXCLUDE_RE:-}"
    ## should not silently match every repo via 'grep -v -E ()'.
    [ -z "${item}" ] && continue
    if [ -z "${out}" ]; then
      out="(${item})"
    else
      out="${out}|(${item})"
    fi
  done
  printf '%s' "${out}"
}

include_re="$(combine_alt include_re_list)"
exclude_re="$(combine_alt exclude_re_list)"

ghorg_require_deps
ghorg_validate_name "${source_owner}" user
ghorg_validate_name "${target_owner}" user

## POST /repos/{owner}/{repo}/forks. The `organization` body field
## applies only when the target is an Organization; for a User it must
## be omitted, and GitHub then forks to the *authenticated* user
## regardless of `target_owner`. Because there is no API parameter to
## name a different user, we explicitly verify the auth user equals
## target_owner up front and refuse otherwise - the alternative is
## creating forks in the wrong account while logs claim otherwise.
fork_one() {
  local repo target_type body auth_user result status

  repo="$1"

  ghorg_validate_name "${repo}" repo || return 1

  target_type="$(ghorg_account_type "${target_owner}")" || return 1

  if [ "${target_type}" = 'Organization' ]; then
    body="$(jq -n --arg org "${target_owner}" -- \
      '{organization: $org, default_branch_only: false}')"
  else
    auth_user="$(ghorg_authenticated_user)" || return 1
    if [ "${auth_user}" != "${target_owner}" ]; then
      log error "target user '${target_owner}' does not match auth user '${auth_user}'; refusing to fork"
      return 1
    fi
    body="$(jq -n -- '{default_branch_only: false}')"
  fi
  if [ "${dry_run}" = '1' ]; then
    log notice "DRY-RUN: fork ${source_owner}/${repo} -> ${target_owner}/${repo}"
    return 0
  fi
  result="$(ghorg_api POST "/repos/${source_owner}/${repo}/forks" "${body}")"
  status="$(ghorg_status_of "${result}")"
  case "${status}" in
    202|201)
      log notice "forked: ${source_owner}/${repo} -> ${target_owner}/${repo}"
      ;;
    *)
      log error "fork '${source_owner}/${repo}': HTTP '${status}'"
      return 1
      ;;
  esac
}

## Detects cross-source name collisions. When a target repo with the
## given name already exists, look up its parent.full_name; if the
## parent isn't the source we're processing, the operator has two
## different upstream repos collapsed onto one mirror name. We warn
## but don't fail - the operator sees the collision and decides what
## to do (rename, archive, or accept).
check_collision() {
  local repo parent expected

  repo="$1"

  parent="$(ghorg_repo_parent "${target_owner}" "${repo}")" || return 0
  expected="${source_owner}/${repo}"

  if [ -n "${parent}" ] && [ "${parent}" != "${expected}" ]; then
    log warn "collision: '${target_owner}/${repo}' exists as fork of '${parent}', expected '${expected}'"
  fi
}

## Apply the optional --disable-* / --actions / --workflow-perms flags
## to a single target repo. Idempotent and skipped entirely when no
## flags were passed.
configure_one() {
  local repo patch enabled body result status

  repo="$1"

  ## Repo settings PATCH only sent if at least one toggle was requested.
  if [ "${disable_issues}${disable_wiki}${disable_projects}" != '000' ]; then
    patch='{}'
    [ "${disable_issues}"   = '1' ] && patch="$(printf '%s' "${patch}" | jq -- '. + {has_issues: false}')"
    [ "${disable_wiki}"     = '1' ] && patch="$(printf '%s' "${patch}" | jq -- '. + {has_wiki: false}')"
    [ "${disable_projects}" = '1' ] && patch="$(printf '%s' "${patch}" | jq -- '. + {has_projects: false}')"
    if [ "${dry_run}" = '1' ]; then
      log notice "DRY-RUN: PATCH ${target_owner}/${repo} ${patch}"
    else
      result="$(ghorg_api PATCH "/repos/${target_owner}/${repo}" "${patch}")"
      status="$(ghorg_status_of "${result}")"
      [ "${status}" != '200' ] && \
        log warn "PATCH '${target_owner}/${repo}': HTTP '${status}'"
      [ "${verbose}" = '1' ] && [ "${status}" = '200' ] && \
        log notice "configured: ${target_owner}/${repo} ${patch}"
    fi
  fi

  if [ "${actions_state}" != 'leave' ]; then
    [ "${actions_state}" = 'enable' ] && enabled='true' || enabled='false'
    body="$(jq -n --argjson e "${enabled}" -- '{enabled: $e, allowed_actions: "all"}')"
    if [ "${dry_run}" = '1' ]; then
      log notice "DRY-RUN: actions ${actions_state} on ${target_owner}/${repo}"
    else
      result="$(ghorg_api PUT "/repos/${target_owner}/${repo}/actions/permissions" "${body}")"
      status="$(ghorg_status_of "${result}")"
      case "${status}" in
        204|200) [ "${verbose}" = '1' ] && \
          log notice "actions=${actions_state} on ${target_owner}/${repo}" ;;
        *) log warn "actions ${actions_state} on ${target_owner}/${repo}: HTTP ${status}" ;;
      esac
    fi
  fi

  if [ "${workflow_perms}" != 'leave' ]; then
    body="$(jq -n --arg p "${workflow_perms}" -- \
      '{default_workflow_permissions: $p, can_approve_pull_request_reviews: false}')"
    if [ "${dry_run}" = '1' ]; then
      log notice "DRY-RUN: workflow-perms ${workflow_perms} on ${target_owner}/${repo}"
    else
      result="$(ghorg_api PUT \
        "/repos/${target_owner}/${repo}/actions/permissions/workflow" "${body}")"
      status="$(ghorg_status_of "${result}")"
      case "${status}" in
        204|200) [ "${verbose}" = '1' ] && \
          log notice "workflow-perms=${workflow_perms} on ${target_owner}/${repo}" ;;
        *) log warn "workflow-perms ${workflow_perms} on ${target_owner}/${repo}: HTTP ${status}" ;;
      esac
    fi
  fi
}

## Fast-forward target_owner/repo's default branch from upstream via
## POST /repos/{owner}/{repo}/merge-upstream. The merge-upstream
## endpoint:
##   200 - synced (or already up-to-date); .merge_type tells the form.
##   409 - upstream and fork have diverged in a way merge-upstream
##         cannot fast-forward (someone pushed to the mirror directly).
##   422 - default branch missing on either side.
## We accept 200 and downgrade 409/422 to warn so a single repo's
## divergence does not abort the run.
##
## Default branch is looked up via /repos/{owner}/{repo}.default_branch.
## Most are 'master', some are 'main' or other names; do not hard-code.
sync_one() {
  local repo result status info default_branch body
  local merge_type merged_commits

  repo="$1"

  if [ "${dry_run}" = '1' ]; then
    log notice "DRY-RUN: sync-branches ${target_owner}/${repo}"
    return 0
  fi

  ## Need the default branch name. Fetch the repo metadata once.
  info="$(ghorg_api GET "/repos/${target_owner}/${repo}")" || return 1
  status="$(ghorg_status_of "${info}")"
  if [ "${status}" != '200' ]; then
    log warn "sync-branches: lookup '${target_owner}/${repo}': HTTP '${status}'"
    return 0
  fi
  default_branch="$(ghorg_body_of "${info}" | jq -r -- '.default_branch')"
  if [ -z "${default_branch}" ] || [ "${default_branch}" = 'null' ]; then
    log warn "sync-branches: '${target_owner}/${repo}' has no default branch"
    return 0
  fi
  ## Default branch is API-derived; passes into the request body
  ## (jq escapes safely) and into display via log() (which sanitizes
  ## internally). The remaining validation here is defense-in-depth.
  ##
  ## Use git's own ref-name validator instead of an inline allowlist.
  ## Branch names can legitimately contain characters beyond a simple
  ## class (e.g. '+'), and any homegrown regex tends to false-positive
  ## on edge cases.
  ##
  ## 'git check-ref-format' does not support '--' as an end-of-options
  ## separator on any of its forms (verified against git 2.43); both
  ## '--branch -- <X>' and '-- <refname>' return usage error 129 even
  ## for valid names. Validate as a full refname instead, prefixing
  ## 'refs/heads/' ourselves. The prefix ensures the resulting argv
  ## element never starts with '-', so the missing '--' end-of-options
  ## doesn't create a shell-level arg-injection path from a hostile
  ## API response.
  if ! git check-ref-format "refs/heads/${default_branch}" >/dev/null 2>&1; then
    log warn "sync-branches: '${target_owner}/${repo}' default branch invalid: '${default_branch}'"
    return 0
  fi

  body="$(jq -n --arg b "${default_branch}" -- '{branch: $b}')"
  result="$(ghorg_api POST \
    "/repos/${target_owner}/${repo}/merge-upstream" "${body}")" || return 1
  status="$(ghorg_status_of "${result}")"
  case "${status}" in
    200)
      merge_type="$(ghorg_body_of "${result}" | jq -r -- '.merge_type')"
      merged_commits="$(ghorg_body_of "${result}" | jq -r -- '.merged_commits // 0')"
      [ "${verbose}" = '1' ] && log notice \
        "synced: ${target_owner}/${repo}/${default_branch} merge_type='${merge_type}' commits='${merged_commits}'"
      ;;
    409)
      log warn "sync-branches: '${target_owner}/${repo}/${default_branch}' diverged from upstream (HTTP 409)"
      ;;
    422)
      log warn "sync-branches: '${target_owner}/${repo}/${default_branch}' branch missing on upstream (HTTP 422)"
      ;;
    *)
      log warn "sync-branches: '${target_owner}/${repo}/${default_branch}': HTTP '${status}'"
      ;;
  esac
}

## Populates the associative array named in $1 with one key per
## newline-separated repo name in $2. Empty lines skipped.
fork_main_build_repo_set() {
  local set_name list_text repo_name

  set_name="$1"
  list_text="$2"

  while IFS= read -r repo_name; do
    [ -z "${repo_name}" ] && continue
    printf -v "${set_name}[${repo_name}]" '%s' '1'
  done <<< "${list_text}"
}

main() {
  local target_type auth_user source_repos target_repos repo_name
  local -A target_set=()
  local -a missing=() to_configure=()

  log notice "source: ${source_owner} -> target: ${target_owner}"

  ## If the target is a User, GitHub will fork to the authenticated
  ## user regardless of target_owner. Verify equivalence up front and
  ## abort the whole run rather than discovering this per repo.
  target_type="$(ghorg_account_type "${target_owner}")"
  if [ "${target_type}" = 'User' ]; then
    auth_user="$(ghorg_authenticated_user)"
    [ "${auth_user}" = "${target_owner}" ] \
      || die 1 "target user '${target_owner}' does not match auth user '${auth_user}'"
  fi

  source_repos="$(ghorg_list_repos "${source_owner}" \
    "${include_private}" "${include_archived}" "${include_forks}" \
    | ghorg_filter_names "${include_re}" "${exclude_re}" \
    | sort --unique)"
  ## Target side: do NOT exclude forks - target forks ARE the mirrors.
  target_repos="$(ghorg_list_repos "${target_owner}" 1 1 1 \
    | sort --unique)"

  if [ -z "${source_repos}" ]; then
    log notice 'no source repos matched.'
    return 0
  fi

  ## Set difference: source repos absent from target.
  ## ${target_set[$key]:-} is required because nounset triggers on an
  ## associative-array subscript with an unset key.
  fork_main_build_repo_set target_set "${target_repos}"
  while IFS= read -r repo_name; do
    [ -z "${repo_name}" ] && continue
    [ -z "${target_set[${repo_name}]:-}" ] && missing+=( "${repo_name}" )
  done <<< "${source_repos}"

  if [ "${#missing[@]}" -eq 0 ]; then
    log notice 'no new forks needed.'
  else
    for repo_name in "${missing[@]}"; do
      fork_one "${repo_name}"
    done
  fi

  ## Re-list target after potential new forks (GitHub fork creation is
  ## async; brand-new forks may not appear yet, but configure_one is
  ## idempotent on the next run).
  target_repos="$(ghorg_list_repos "${target_owner}" 1 1 1 \
    | sort --unique)"

  ## Set intersection: source repos that exist on target. Configures
  ## only matching repos; leaves unrelated target-side repos alone.
  target_set=()
  fork_main_build_repo_set target_set "${target_repos}"
  while IFS= read -r repo_name; do
    [ -z "${repo_name}" ] && continue
    [ -n "${target_set[${repo_name}]:-}" ] && to_configure+=( "${repo_name}" )
  done <<< "${source_repos}"

  ## Best-effort: a single repo's check_collision or configure_one
  ## failing must not abort the whole run. Common transient cause is
  ## that GitHub fork creation is async; right after POST /forks
  ## returns 202 the fork's Actions subsystem may not yet accept
  ## PUT /repos/{owner}/{repo}/actions/permissions and that returns
  ## 404/403. Without '|| true' here, errexit would skip every
  ## subsequent repo and any further source orgs the caller queues.
  ## A second run picks the failures up idempotently.
  if [ "${#to_configure[@]}" -gt 0 ]; then
    for repo_name in "${to_configure[@]}"; do
      check_collision "${repo_name}" || true
      configure_one "${repo_name}" || true
    done
  fi

  ## Branch sync (--sync-branches). Same best-effort guarantee.
  ## sync_one calls 'git check-ref-format' to validate API-derived
  ## default branch names; check git up-front so a missing binary
  ## fails loudly instead of silently rejecting every repo.
  if [ "${sync_branches}" = '1' ] && [ "${#to_configure[@]}" -gt 0 ]; then
    has git || die 1 "'git' not on PATH (required by --sync-branches)"
    for repo_name in "${to_configure[@]}"; do
      sync_one "${repo_name}" || true
    done
  fi
}

main
