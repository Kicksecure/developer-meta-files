## Project-wide ShellCheck configuration.
## Mirrors the exclusion list in usr/bin/dm-shellcheck-wrapper plus:
##   SC2154 - variables defined in sourced help-steps/* files
##   SC1091 - sourced files outside the repo (help-steps, /usr/libexec)

disable=SC2086
disable=SC2016
disable=SC2034
disable=SC2129
disable=SC2004
disable=SC2088
disable=SC2015
disable=SC2068
disable=SC2001
disable=SC2154
disable=SC1091
